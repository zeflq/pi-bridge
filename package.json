{
  "name": "pi-bridge",
  "version": "0.3.0",
  "description": "Transparent filesystem bridge that makes pi run natively on a remote machine over SSH",
  "type": "commonjs",
  "bin": {
    "pii": "bin/pii.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
