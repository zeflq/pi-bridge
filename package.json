    "remote",
    "filesystem"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeflq/pi-bridge.git"
  },
  "homepage": "https://github.com/zeflq/pi-bridge#readme",
  "bugs": {
    "url": "https://github.com/zeflq/pi-bridge/issues"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
